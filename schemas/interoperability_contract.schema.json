  "examples": [
    {
      "contract_version": "0.1",
      "handoff_id": "support-agent-to-email-send-001",
      "sender": {
        "id": "support_agent",
        "type": "agent",
        "trust_tier": "system"
      },
      "recipient": {
        "id": "email_send_guardrail",
        "type": "adapter",
        "adapter_id": "email_send_guardrail",
        "trust_tier": "system"
      },
      "message_schema": {
        "kind": "candidate_action",
        "schema_id": "email-send-draft-v0.1",
        "content_type": "text/plain",
        "redaction_required": true
      },
      "message": {
        "summary": "Draft email would promise a full refund.",
        "payload_redaction_status": "redacted",
        "claims": ["Customer is eligible for a full refund."],
        "assumptions": [
          {
            "id": "refund-eligibility-known",
            "description": "Refund eligibility is known and approved.",
            "support_status": "contradicted",
            "evidence_source_id": "crm-record"
          }
        ]
      },
      "evidence": [
        {
          "source_id": "crm-record",
          "retrieved_at": "2026-05-05T00:00:00Z",
          "trust_tier": "verified",
          "redaction_status": "redacted",
          "text": "Refund eligibility is unknown.",
          "retrieval_url": "aana://evidence/crm-record",
          "limits": ["Does not support a refund promise."]
        }
      ],
      "constraint_map": {
        "K_P": [
          {
            "id": "refund-evidence-required",
            "description": "Refund eligibility must be supported by verified account evidence.",
            "severity": "high",
            "hard": true,
            "source": "support_policy_registry"
          }
        ],
        "K_B": [
          {
            "id": "do-not-mislead-customer",
            "description": "Do not mislead the customer about account status or remedies.",
            "severity": "high",
            "hard": true,
            "source": "support_policy_registry"
          }
        ],
        "K_C": [
          {
            "id": "no-unsupported-refund-promise",
            "description": "Do not send refund promises without policy eligibility.",
            "severity": "high",
            "hard": true,
            "source": "email_send_guardrail"
          }
        ],
        "F": [
          {
            "id": "evidence-freshness",
            "description": "CRM evidence must be fresh enough for the support decision.",
            "severity": "medium",
            "hard": false,
            "source": "crm_support"
          }
        ],
        "hard_blockers": ["refund-evidence-required", "no-unsupported-refund-promise"]
      },
      "verifier_scores": {
        "P": {
          "score": 0.2,
          "status": "fail",
          "confidence": 0.9,
          "verifier_ids": ["refund_evidence_verifier"]
        },
        "B": {
          "score": 0.4,
          "status": "fail",
          "confidence": 0.85,
          "verifier_ids": ["customer_misrepresentation_verifier"]
        },
        "C": {
          "score": 0.2,
          "status": "fail",
          "confidence": 0.95,
          "verifier_ids": ["support_policy_verifier"]
        },
        "F": {
          "score": 0.8,
          "status": "pass",
          "confidence": 0.8,
          "verifier_ids": ["evidence_freshness_verifier"]
        },
        "overall": 0.35
      },
      "aix": {
        "aix_version": "0.1",
        "score": 0.31,
        "components": {
          "P": 0.2,
          "B": 0.4,
          "C": 0.2,
          "F": 0.8
        },
        "beta": 1.5,
        "thresholds": {
          "accept": 0.9,
          "revise": 0.7,
          "defer": 0.55
        },
        "decision": "refuse",
        "hard_blockers": ["refund-evidence-required", "no-unsupported-refund-promise"]
      },
      "gate_decision": "block",
      "recommended_action": "revise",
      "allowed_actions": ["accept", "revise", "retrieve", "ask", "defer", "refuse"],
      "violations": [
        {
          "id": "unsupported-refund-promise",
          "layer": "C",
          "severity": "high",
          "message": "The draft promises a refund that the evidence does not support.",
          "constraint_id": "no-unsupported-refund-promise",
          "evidence_source_id": "crm-record",
          "hard": true
        }
      ],
      "audit_summary": {
        "handoff_id": "support-agent-to-email-send-001",
        "sender_id": "support_agent",
        "recipient_id": "email_send_guardrail",
        "gate_decision": "block",
        "recommended_action": "revise",
        "aix_score": 0.31,
        "aix_decision": "refuse",
        "hard_blockers": ["refund-evidence-required", "no-unsupported-refund-promise"],
        "violation_codes": ["unsupported-refund-promise"]
      }
    }
