# Live model calls use OpenAI by default.
AANA_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Optional: use a Responses-compatible endpoint without changing code.
# AANA_API_KEY=your_provider_key_here
# AANA_BASE_URL=https://api.openai.com/v1
# AANA_RESPONSES_URL=https://api.openai.com/v1/responses

# Optional: use Anthropic's native Messages API.
# AANA_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_VERSION=2023-06-01
