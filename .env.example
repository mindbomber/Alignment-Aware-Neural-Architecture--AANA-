# Live model calls use OpenAI by default.
AANA_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# Optional: use a Responses-compatible endpoint without changing code.
# AANA_API_KEY=your_provider_key_here
# AANA_BASE_URL=https://api.openai.com/v1
# AANA_RESPONSES_URL=https://api.openai.com/v1/responses

# Optional: use Anthropic's native Messages API.
# AANA_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_VERSION=2023-06-01

# Optional: Dockerized local production-candidate FastAPI runtime.
# Copy examples/aana_bridge.env.example to .env for a complete runtime profile.
AANA_BRIDGE_TOKEN=aana-local-dev-token
AANA_BRIDGE_PORT=8765
AANA_ADAPTER_GALLERY=examples/adapter_gallery.json
AANA_AUDIT_LOG=eval_outputs/audit/docker/aana-fastapi.jsonl
AANA_BRIDGE_TOKEN_SCOPES=pre_tool_check,agent_check,workflow_check,workflow_batch,validation,aix_audit,durable_audit_storage,human_review_export,live_monitoring,enterprise_connectors,enterprise_live_connectors,enterprise_demo,mlcommons_aix_report,production_candidate_profile,production_candidate_check
AANA_MAX_REQUEST_BYTES=1048576
AANA_RATE_LIMIT_PER_MINUTE=60
AANA_EVIDENCE_REGISTRY=examples/evidence_registry.json
AANA_PRODUCTION_CANDIDATE_PROFILE=examples/production_candidate_profile_enterprise_support.json
AANA_LIVE_CONNECTOR_CONFIG=examples/enterprise_support_live_connectors.json
AANA_LIVE_MONITORING_CONFIG=examples/live_monitoring_metrics.json
