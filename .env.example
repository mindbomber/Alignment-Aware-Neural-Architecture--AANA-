# Live model calls use the OpenAI Responses API by default.
OPENAI_API_KEY=your_openai_api_key_here

# Optional: use a Responses-compatible endpoint without changing code.
# AANA_API_KEY=your_provider_key_here
# AANA_BASE_URL=https://api.openai.com/v1
# AANA_RESPONSES_URL=https://api.openai.com/v1/responses
