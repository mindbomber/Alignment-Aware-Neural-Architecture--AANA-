      "requirement": "Support adapters run through Workflow Contract and Agent Event Contract paths.",
      "status": "repo_local_validated",
      "evidence": [
        "tests/test_runtime_boundary_cleanup.py",
        "tests/test_support_workflow_contract_examples.py",
        "examples/support_workflow_contract_examples.json"
      ],
      "release_gate": "unit_tests"
    },
    {
      "id": "registry_driven_runtime_routing",
      "requirement": "Runtime routing is registry-driven.",
      "status": "repo_local_validated",
      "evidence": [
        "eval_pipeline/adapter_runner/registry.py",
        "eval_pipeline/adapter_runner/verifier_catalog.py",
        "tests/test_runtime_boundary_cleanup.py"
      ],
      "release_gate": "unit_tests"
    },
    {
      "id": "support_evidence_connectors",
      "requirement": "Live or approved support evidence connector boundaries exist for CRM, orders, refund policy, ticket history, recipient verification, attachments, account verification, billing redaction, and support policy.",
      "status": "repo_local_approved_fixture_boundary",
      "evidence": [
        "examples/evidence_registry.json",
        "examples/evidence_mock_connector_fixtures.json",
        "tests/test_evidence_integrations.py"
      ],
      "release_gate": "production_profiles"
    },
    {
      "id": "audit_safe_records",
      "requirement": "Audit-safe records are emitted without raw support content.",
