    "must_verify_channel_and_recipients": true,
    "must_check_mentions_and_broadcast_scope": true,
    "must_check_private_data_before_send": true,
    "must_not_treat_draft_as_send_approval": true,
    "must_block_unsafe_or_unauthorized_send": true
  },
  "aana_boundary": {
    "checker_bundled": false,
    "checker_required": false
  },
  "schemas": [
    "schemas/message-send-guardrail.schema.json"
  ],
  "examples": [
    "examples/redacted-message-send-guardrail.json"
  ]
