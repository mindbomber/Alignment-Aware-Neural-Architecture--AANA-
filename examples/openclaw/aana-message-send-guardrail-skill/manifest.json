{
  "name": "aana-message-send-guardrail",
  "slug": "aana-message-send-guardrail",
  "version": "0.1.0",
  "type": "instruction_only_skill",
  "description": "AANA-grounded message send guardrail instructions for checking chat recipients, channel visibility, tone, private data, claims, and send approval.",
