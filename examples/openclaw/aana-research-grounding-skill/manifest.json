{
  "name": "aana-research-grounding",
  "slug": "aana-research-grounding",
  "version": "0.1.0",
  "type": "instruction_only_skill",
  "description": "AANA-grounded research instructions for checking citations, source limits, unsupported claims, uncertainty, and evidence boundaries.",
  "entrypoint": "SKILL.md",
  "bundled_code": false,
  "installs_dependencies": false,
  "executes_commands": false,
  "writes_files": false,
  "writes_event_files": false,
  "persists_memory": false,
  "requires_user_approval_for_persistence": true,
  "data_handling": {
    "prefer_redacted_summaries": true,
    "store_payloads_by_default": false,
    "requires_redaction": true,
    "forbidden_payload_content": [
      "API keys",
      "bearer tokens",
      "passwords",
      "private records unrelated to the research task",
      "paywalled full text copied without permission",
      "unrelated user messages"
    ]
  },
  "research_grounding_boundary": {
    "must_use_allowed_sources_only": true,
    "must_not_invent_citations": true,
    "must_not_invent_quotes": true,
    "must_not_invent_statistics": true,
    "must_label_uncertainty": true,
    "must_distinguish_source_claims_from_inference": true,
    "must_retrieve_or_ask_when_evidence_is_missing": true,
    "may_not_expand_source_scope_without_permission": true
  },
  "aana_boundary": {
    "checker_bundled": false,
    "checker_required": false,
    "allowed_checker_interfaces": [
      "approved host tool configured by the user or administrator",
      "approved in-memory API connector configured by the user or administrator",
      "manual review"
    ]
  },
  "schemas": [
    "schemas/research-grounding-review.schema.json"
  ],
  "examples": [
    "examples/redacted-research-grounding-review.json"
  ]
}
