{
  "title": "AANA Medical Safety Review",
  "type": "object",
  "required": [
    "task_summary",
    "medical_context",
    "risk_level",
    "emergency_status",
    "diagnosis_overclaim_status",
    "treatment_overclaim_status",
    "recommended_action"
  ],
  "properties": {
    "task_summary": {
      "type": "string",
      "minLength": 1
    },
    "medical_context": {
      "type": "string",
      "enum": [
        "general_education",
        "wellness",
        "symptom_triage",
        "medication",
        "dosage",
        "side_effect",
        "diagnosis",
        "treatment",
        "lab_result",
        "medical_record",
        "mental_health",
        "self_harm_or_crisis",
        "pregnancy",
        "pediatric",
        "emergency",
        "unknown"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "moderate",
        "high",
        "emergency",
        "crisis",
        "unknown"
      ]
    },
    "emergency_status": {
      "type": "string",
      "enum": [
        "none_detected",
        "possible_urgent_warning_signs",
        "emergency_route_required",
        "crisis_route_required",
        "not_checked",
        "unknown"
      ]
    },
    "diagnosis_overclaim_status": {
      "type": "string",
      "enum": [
        "none",
        "overclaim_detected",
        "uncertainty_needed",
        "not_checked",
        "unknown"
      ]
    },
    "treatment_overclaim_status": {
      "type": "string",
      "enum": [
        "none",
        "prescription_or_dosage_overclaim",
        "unsafe_treatment_claim",
        "clinician_referral_needed",
        "not_checked",
        "unknown"
      ]
    },
    "privacy_status": {
      "type": "string",
      "enum": [
        "minimal",
        "needs_redaction",
        "private_health_data_exposed",
        "not_checked",
        "unknown"
      ]
    },
    "referral_target": {
      "type": "string",
      "enum": [
        "none",
        "clinician",
        "pharmacist",
        "emergency_services",
        "crisis_support",
        "qualified_local_professional",
        "unknown"
      ]
    },
    "unsupported_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safeguards_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "accept",
        "revise",
        "ask",
        "retrieve",
        "defer",
        "emergency_route",
        "crisis_route",
        "refuse"
      ]
    },
    "human_review_required": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
