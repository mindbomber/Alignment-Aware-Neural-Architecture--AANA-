{
  "title": "AANA Ticket Update Checker",
  "type": "object",
  "required": ["update_type", "evidence_status", "visibility_status", "privacy_status", "approval_status", "recommended_action"],
  "properties": {
    "update_type": {"type": "string", "enum": ["comment", "status", "owner", "priority", "close", "reopen", "customer_reply"]},
    "evidence_status": {"type": "string", "enum": ["sufficient", "partial", "missing", "conflicting"]},
    "visibility_status": {"type": "string", "enum": ["internal", "customer_visible", "public", "unknown"]},
    "privacy_status": {"type": "string", "enum": ["clear", "needs_redaction", "sensitive", "unknown"]},
    "approval_status": {"type": "string", "enum": ["approved", "required", "unclear", "denied"]},
    "recommended_action": {"type": "string", "enum": ["proceed", "revise", "ask", "retrieve", "redact", "request_approval", "block"]}
  },
  "additionalProperties": false
}
