    "destination_status": {"type": "string", "enum": ["local", "user", "external", "public", "unknown"]},
    "privacy_status": {"type": "string", "enum": ["clear", "needs_redaction", "sensitive", "regulated"]},
    "approval_status": {"type": "string", "enum": ["approved", "required", "unclear", "denied"]},
    "recommended_action": {"type": "string", "enum": ["proceed", "narrow", "ask", "redact", "request_approval", "route_to_review", "block"]}
  },
  "additionalProperties": false
