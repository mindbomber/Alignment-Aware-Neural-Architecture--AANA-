{
  "name": "aana-task-scope-guardrail",
  "slug": "aana-task-scope-guardrail",
  "version": "0.1.0",
  "type": "instruction_only_skill",
  "description": "AANA-grounded task scope guardrail instructions for preventing agents from expanding tasks, using unrelated data, or continuing after completion.",
  "entrypoint": "SKILL.md",
  "bundled_code": false,
  "installs_dependencies": false,
  "executes_commands": false,
  "writes_files": false,
  "writes_event_files": false,
  "persists_memory": false,
  "prevents_task_expansion": true,
  "requires_task_relevant_data": true,
  "requires_stop_after_completion": true,
  "data_handling": {
    "prefer_redacted_summaries": true,
    "store_payloads_by_default": false,
    "requires_data_minimization": true,
    "forbidden_payload_content": [
      "API keys",
      "bearer tokens",
      "passwords",
      "private keys",
      "security codes",
      "full payment numbers",
      "raw medical records",
      "raw legal records",
      "raw financial records",
      "full private messages",
      "full logs with sensitive values",
      "full account records",
      "unrelated private data",
      "unrelated task history"
    ]
  },
  "task_scope_boundary": {
    "must_identify_current_user_request": true,
    "must_define_completion_target": true,
    "must_classify_proposed_next_action": true,
    "must_use_only_task_relevant_data": true,
    "must_not_expand_scope_without_approval": true,
    "must_stop_after_request_is_complete": true,
    "must_ask_when_scope_is_ambiguous": true,
    "must_treat_optional_work_as_suggestion_only": true,
    "must_not_continue_background_work": true
  },
  "aana_boundary": {
    "checker_bundled": false,
    "checker_required": false,
    "allowed_checker_interfaces": [
      "approved host tool configured by the user or administrator",
      "approved in-memory API connector configured by the user or administrator",
      "manual review"
    ]
  },
  "schemas": [
    "schemas/task-scope-gate.schema.json"
  ],
  "examples": [
    "examples/redacted-task-scope-gate.json"
  ]
}
