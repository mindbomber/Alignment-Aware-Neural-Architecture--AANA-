{
  "policy_name": "AANA Internal Pilot Observability",
  "owner": "AANA Platform Operations Owner",
  "dashboard_url": "https://aana.internal.example/observability/support-runtime",
  "dashboards": [
    {
      "id": "support-runtime-operations",
      "title": "AANA Support Runtime Operations",
      "url": "https://aana.internal.example/observability/support-runtime",
      "metrics_source": "immutable-audit://aana-internal-pilot/support/decision-metadata",
      "owner": "AANA Platform Operations Owner",
      "panels": [
        {
          "id": "gate_decisions",
          "title": "Gate Decisions by Adapter",
          "metric": "gate_decision_count"
        },
        {
          "id": "recommended_actions",
          "title": "Recommended Actions",
          "metric": "recommended_action_count"
        },
        {
          "id": "refusal_defer_rate",
          "title": "Refusal and Defer Rate",
          "metric": "refusal_defer_rate"
        },
        {
          "id": "connector_failures",
          "title": "Connector Failures",
          "metric": "connector_failure_count"
        },
        {
          "id": "evidence_freshness",
          "title": "Stale Evidence and Freshness Failures",
          "metric": "evidence_freshness_failure_count"
        },
        {
          "id": "latency",
          "title": "Latency p95",
          "metric": "latency.p95_ms"
        },
        {
          "id": "aix_drift",
          "title": "AIx Score and Decision Drift",
          "metric": "aix_score_average"
        },
        {
          "id": "hard_blockers",
          "title": "AIx Hard Blockers",
          "metric": "aix_hard_blocker_count"
        }
      ]
    }
  ],
  "tracked_metrics": [
    "adapter_error_count",
    "aix_decision_count",
    "aix_hard_blocker_count",
    "aix_score_average",
    "candidate_aix_score_average",
    "connector_failure_count",
    "correction_success_rate",
    "evidence_freshness_failure_count",
    "evidence_integrity_failure_count",
    "false_accept_rate",
    "false_block_rate",
    "gate_decision_count",
    "human_review_turnaround_time",
    "latency",
    "over_refusal_rate",
    "recommended_action_count",
    "refusal_defer_rate",
    "shadow_records_total",
    "shadow_would_action_count",
    "violation_code_count"
  ],
  "alerts": [
    {
      "id": "high_refusal_defer_rate",
      "name": "High refusal/defer rate",
      "metric": "refusal_defer_rate",
      "condition": "greater_than",
      "threshold": 0.2,
      "severity": "high",
      "route": "AANA Internal Pilot Incident Log",
      "owner": "AANA Platform On-Call"
    },
    {
      "id": "connector_failures",
      "name": "Connector failures",
      "metric": "connector_failure_count",
      "condition": "greater_than",
      "threshold": 0,
      "severity": "critical",
      "route": "AANA Internal Pilot Incident Log",
      "owner": "AANA Platform On-Call"
    },
    {
      "id": "stale_evidence",
      "name": "Stale evidence",
      "metric": "evidence_freshness_failure_count",
      "condition": "greater_than",
      "threshold": 0,
      "severity": "high",
      "route": "AANA Evidence Review Queue",
      "owner": "AANA Evidence On-Call"
    },
    {
      "id": "latency_spike",
      "name": "P95 latency breach",
      "metric": "latency.p95_ms",
      "condition": "greater_than",
      "threshold": 2000,
      "severity": "medium",
      "route": "AANA Platform Operations Queue",
      "owner": "AANA Platform On-Call"
    },
    {
      "id": "aix_drift",
      "name": "AIx drift",
      "metric": "aix_score_average",
      "condition": "less_than",
      "threshold": 0.85,
      "severity": "high",
      "route": "AANA Internal Pilot Human Review Queue",
      "owner": "AANA Safety On-Call"
    },
    {
      "id": "hard_blocker_spike",
      "name": "AIx hard-blocker spike",
      "metric": "aix_hard_blocker_count",
      "condition": "greater_than",
      "threshold": 0,
      "severity": "high",
      "route": "AANA Internal Pilot Incident Log",
      "owner": "AANA Safety On-Call"
    }
  ],
  "drift_review": {
    "cadence": "weekly",
    "owner": "AANA Platform Operations Owner",
    "required_reports": [
      "adapter_error_trend",
      "aix_decision_distribution",
      "aix_hard_blocker_review",
      "aix_score_trend",
      "connector_failure_trend",
      "evidence_freshness_failure_trend",
      "false_accept_false_block_review",
      "human_review_turnaround",
      "latency_trend",
      "pass_block_fail_trend",
      "recommended_action_distribution",
      "refusal_defer_rate_trend",
      "top_violation_codes"
    ]
  },
  "latency_slo": {
    "p95_ms": 2000,
    "route": "AANA Platform Operations Queue"
  },
  "on_call": {
    "primary": "AANA Platform On-Call",
    "secondary": "AANA Safety On-Call",
    "schedule": "https://aana.internal.example/on-call/aana-platform",
    "escalation_policy": "AANA Internal Pilot Severity Policy",
    "handoff": "Daily handoff in AANA Internal Pilot Incident Log",
    "incident_channel": "AANA Internal Pilot Incident Log",
    "page_for": [
      "high_refusal_defer_rate",
      "connector_failures",
      "stale_evidence",
      "latency_spike",
      "aix_drift",
      "hard_blocker_spike"
    ]
  }
}
