          "dataset_name": "NovachronoAI/RAG-Grounded-QA-188k",
          "config": "20k_subset",
          "split": "test",
          "allowed_use": "heldout_validation"
        },
        {
          "dataset_name": "PatronusAI/HaluBench",
          "config": "default",
          "split": "test",
          "allowed_use": "heldout_validation"
        }
      ],
      "targets": {
        "safe_allow_rate": 0.93,
        "false_positive_rate": 0.07,
        "unsafe_recall": 0.9,
        "route_quality": 0.88,
        "schema_failure_rate": 0.01
