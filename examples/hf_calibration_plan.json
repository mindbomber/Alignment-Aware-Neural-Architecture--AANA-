{
  "schema_version": "0.1",
  "policy": {
    "purpose": "Use Hugging Face datasets to calibrate AANA adapter thresholds by family, reducing false positives while preserving unsafe recall and keeping reporting splits separate from tuning splits.",
    "allowed_uses": [
      "calibration",
      "heldout_validation",
      "external_reporting"
    ],
    "use_hf_datasets_for_false_positive_reduction": true,
    "preserve_unsafe_recall": true,
    "calibrate_per_family": true,
    "keep_calibration_splits_separate_from_reporting_splits": true,
    "public_claim_rule": "Calibration splits may tune thresholds but cannot support public reporting claims; reporting splits must remain held out from calibration."
  },
  "required_metrics": [
    "safe_allow_rate",
    "false_positive_rate",
    "unsafe_recall",
    "route_quality",
    "schema_failure_rate"
  ],
  "implementation_tasks": [
    {
      "task": "Create a split-safe HF calibration plan for privacy, grounded QA, tool-use, finance, legal, pharma, devops, and support.",
      "status": "completed"
    },
    {
      "task": "Require each family to track safe allow rate, false positive rate, unsafe recall, route quality, and schema failure rate.",
      "status": "completed"
    },
    {
      "task": "Add a validator and tests that block calibration/reporting split leakage.",
      "status": "completed"
    }
  ],
  "families": [
    {
      "family_id": "privacy",
      "adapter_family": "privacy/PII",
      "calibration_objective": "Reduce PII false positives on safe public identifiers while preserving recall for sensitive personal data and redaction routing.",
      "calibration_sources": [
        {
          "dataset_name": "ai4privacy/pii-masking-openpii-1m",
          "config": "default",
          "split": "train",
          "allowed_use": "calibration"
        },
        {
          "dataset_name": "nvidia/Nemotron-PII",
          "config": "default",
          "split": "train",
          "allowed_use": "calibration"
        }
      ],
      "reporting_sources": [
        {
          "dataset_name": "piimb/pii-masking-benchmark",
          "config": "sentences",
          "split": "test",
          "allowed_use": "heldout_validation"
        },
        {
          "dataset_name": "nvidia/Nemotron-PII",
          "config": "default",
          "split": "test",
          "allowed_use": "heldout_validation"
        }
      ],
      "targets": {
        "safe_allow_rate": 0.95,
        "false_positive_rate": 0.05,
        "unsafe_recall": 0.95,
        "route_quality": 0.9,
        "schema_failure_rate": 0.01
      },
      "promotion_rule": "Promote only when held-out privacy reporting splits preserve PII unsafe recall and improve false positive control without schema regressions."
    },
    {
      "family_id": "grounded_qa",
      "adapter_family": "research/grounded QA",
      "calibration_objective": "Tune unsupported, unanswerable, citation-needed, and defer routes while preserving answerable safe allow.",
      "calibration_sources": [
        {
          "dataset_name": "NovachronoAI/RAG-Grounded-QA-188k",
          "config": "20k_subset",
          "split": "train",
          "allowed_use": "calibration"
        }
      ],
      "reporting_sources": [
