{
  "allowlist_version": "0.1",
  "scope": "deployment security review",
  "scan_targets": [
    "deploy",
    "docs",
    "eval_pipeline",
    "examples",
    "scripts",
    "tests",
    "README.md",
    "SECURITY.md"
  ],
  "allowlist": [
    {
      "id": "synthetic_bridge_token_unit_tests",
      "path": "tests/test_*.py",
      "pattern_id": "credential_assignment",
      "match": "secret-token",
      "reason": "Synthetic token literal used only to prove bridge auth and redaction behavior."
    },
    {
      "id": "synthetic_bridge_bearer_unit_tests",
      "path": "tests/test_*.py",
      "pattern_id": "bearer_token",
      "match": "secret-token",
      "reason": "Synthetic bearer token literal used only to prove bridge auth and redaction behavior."
    },
    {
      "id": "synthetic_docs_redaction_examples",
      "path": "docs/*.md",
      "match": "secret-token",
      "reason": "Synthetic redaction example text; not a deployment credential."
    },
    {
      "id": "synthetic_code_review_api_key_fixture",
      "path": "*",
      "pattern_id": "credential_assignment",
      "match": "sk-live-secret-123",
      "reason": "Synthetic unsafe-code-review fixture used to test detection of leaked API key text."
    },
    {
      "id": "synthetic_pilot_certification_token",
      "path": "eval_pipeline/pilot_certification.py",
      "pattern_id": "credential_assignment",
      "match": "pilot-certification-token",
      "reason": "Synthetic local pilot certification token used only in repo-local smoke checks."
    },
    {
      "id": "synthetic_local_demo_token",
      "path": "scripts/demos/run_*.py",
      "pattern_id": "credential_assignment",
      "match": "aana-local-dev-token",
      "reason": "Synthetic local demo token fallback used outside production deployment."
    },
    {
      "id": "synthetic_evidence_redaction_secret_fixture",
      "path": "tests/test_evidence_handling_hardening.py",
      "pattern_id": "credential_assignment",
      "match": "sk-test1234567890abcdef",
      "reason": "Synthetic evidence handling fixture used to prove secret-like summaries are rejected."
    },
    {
      "id": "synthetic_enterprise_negative_payload_secret_fixture",
      "path": "tests/test_enterprise_negative_safety.py",
      "pattern_id": "credential_assignment",
      "match": "sk-proj-negative-secret-1234567890",
      "reason": "Synthetic enterprise negative-safety fixture used to prove raw secret-like payloads are redacted from generated audit artifacts."
    }
  ]
}
