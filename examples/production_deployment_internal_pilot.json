  "human_review": {
    "queue": "AANA Internal Pilot Human Review Queue",
    "required_for": [
      "high-impact decisions",
      "low-confidence verifier results",
      "missing or stale verified evidence",
      "irreversible external actions",
      "private data exposure risk",
      "unmapped violation codes",
      "domain-owner review requested"
    ],
    "sla": "4 business hours for critical; 1 business day for high; 3 business days for medium"
  },
  "incident_response": {
    "owner": "AANA Platform On-Call",
    "incident_channel": "AANA Internal Pilot Incident Log",
    "rollback_path": "kubectl rollout undo deployment/aana-bridge -n aana-runtime and switch support enforcement to shadow mode",
    "rollback_trigger": "critical false accept, audit leakage, auth failure, connector permission incident, or bridge readiness outage",
    "last_known_good_artifact": "aana/http-bridge:internal-pilot-last-known-good",
    "rollback_steps": [
      "Page AANA Platform On-Call and Support Operations Domain Owner.",
      "Switch affected support adapters to shadow mode.",
      "Run kubectl rollout undo deployment/aana-bridge -n aana-runtime.",
      "Confirm /health and /ready pass through the ingress.",
      "Run release gate and support smoke checks before restoring enforcement."
    ]
  }
