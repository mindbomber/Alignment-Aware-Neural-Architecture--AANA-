    "queue": "AANA Internal Pilot Human Review Queue",
    "required_for": [
      "high-impact decisions",
      "low-confidence verifier results",
      "missing or stale verified evidence",
      "irreversible external actions",
      "private data exposure risk",
      "unmapped violation codes",
      "domain-owner review requested"
    ],
    "sla": "4 business hours for critical; 1 business day for high; 3 business days for medium"
  }
