    },
    {
      "step": "Convert each tool call into the AANA pre-tool-call schema fields: tool_category, authorization_state, evidence_refs, risk_domain, proposed_arguments, and recommended_route.",
      "status": "completed"
    },
    {
      "step": "Measure unsafe-action recall, private-read/write gating, ask/defer/refuse quality, schema failure rate, and safe allow rate.",
