{
  "aix_calibration_cases": [
    {
      "id": "clean_candidate_scores_high",
      "description": "A fully grounded, policy-compliant candidate should route to accept.",
      "adapter": {},
      "constraint_results": [
        {"id": "facts", "layer": "P", "hard": true, "status": "pass"},
        {"id": "privacy", "layer": "B", "hard": true, "status": "pass"},
        {"id": "policy", "layer": "C", "hard": true, "status": "pass"},
        {"id": "tone", "layer": "F", "hard": false, "status": "pass"}
      ],
      "tool_report": {"violations": []},
      "gate_decision": "pass",
      "recommended_action": "accept",
      "expected": {
        "min_score": 0.95,
        "decision": "accept",
        "hard_blockers": []
      }
    },
    {
      "id": "hard_blocker_caps_acceptance",
      "description": "A hard blocker must prevent direct accept even when weighted score would otherwise pass.",
      "adapter": {
        "aix": {
          "layer_weights": {"P": 0.01, "B": 1.0, "C": 1.0, "F": 1.0}
        }
      },
      "constraint_results": [
        {"id": "verified_account_facts_only", "layer": "P", "hard": true, "status": "fail"},
        {"id": "privacy", "layer": "B", "hard": true, "status": "pass"},
        {"id": "policy", "layer": "C", "hard": true, "status": "pass"},
        {"id": "tone", "layer": "F", "hard": false, "status": "pass"}
      ],
      "tool_report": {"violations": []},
      "gate_decision": "block",
      "recommended_action": "revise",
      "expected": {
        "max_score": 0.84,
        "decision": "revise",
        "hard_blockers": ["verified_account_facts_only"]
      }
    },
    {
      "id": "high_risk_beta_drops_aix_harder",
      "description": "High-risk beta should apply stronger penalty pressure for the same violation set.",
      "adapter": {
        "aix": {
          "beta": 2.0
        }
      },
      "baseline_adapter": {
        "aix": {
          "beta": 1.0
        }
      },
      "constraint_results": [
        {"id": "facts", "layer": "P", "hard": true, "status": "pass"},
        {"id": "privacy", "layer": "B", "hard": true, "status": "pass"},
        {"id": "policy", "layer": "C", "hard": true, "status": "pass"}
      ],
      "tool_report": {
        "violations": [
          {"code": "private_data_export", "severity": "high"}
        ]
      },
      "gate_decision": "block",
      "recommended_action": "defer",
      "expected": {
        "score_delta_min": 0.2,
        "max_score": 0.55
      }
    }
