# Copy values into a local .env file or export them before running docker compose.
# The default compose token is for local demos only. Use a long random value for pilots.
AANA_BRIDGE_TOKEN=aana-local-dev-token
AANA_BRIDGE_PORT=8765

# Runtime paths inside the container.
AANA_ADAPTER_GALLERY=examples/adapter_gallery.json
AANA_AUDIT_LOG=eval_outputs/audit/docker/aana-bridge.jsonl

# HTTP bridge safety limits.
AANA_MAX_BODY_BYTES=1048576
AANA_RATE_LIMIT_PER_MINUTE=0
AANA_READ_TIMEOUT_SECONDS=30

# Example production-profile artifacts used by release checks and pilot review.
AANA_DEPLOYMENT_MANIFEST=examples/production_deployment_internal_pilot.json
AANA_GOVERNANCE_POLICY=examples/human_governance_policy_internal_pilot.json
AANA_EVIDENCE_REGISTRY=examples/evidence_registry.json
AANA_OBSERVABILITY_POLICY=examples/observability_policy_internal_pilot.json
