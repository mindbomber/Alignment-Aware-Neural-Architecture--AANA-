{
  "schema_version": "0.1",
  "policy": {
    "purpose": "Use Hugging Face datasets to improve and validate AANA adapter families without turning public datasets into benchmark-fitting targets.",
    "allowed_uses": [
      "calibration",
      "heldout_validation",
      "external_reporting"
    ],
    "never_use_same_split_for_tuning_and_public_claims": true,
    "public_claim_rule": "A dataset/config/split used for calibration or tuning cannot also support external_reporting claims.",
    "adapter_claim_boundary": "Datasets may support auditability, control, verification, correction, privacy, groundedness, and routing claims before any raw agent-performance claim."
  },
  "implementation_tasks": [
    {
      "task": "Create a machine-readable HF dataset validation registry.",
      "status": "completed"
    },
    {
      "task": "Track dataset name, license, task type, split use, adapter family, and allowed use.",
      "status": "completed"
    },
    {
      "task": "Enforce split isolation so tuning/calibration splits cannot become public-claim splits.",
      "status": "completed"
    },
    {
      "task": "Add CLI and tests so the registry is part of repo governance.",
      "status": "completed"
    }
  ],
  "datasets": [
    {
      "dataset_name": "piimb/pii-masking-benchmark",
      "license": "cc-by-nc-4.0",
      "task_type": "privacy_pii_masking",
      "adapter_families": [
        "privacy",
        "security",
        "support",
        "agent_tool_gate"
      ],
      "source_url": "https://huggingface.co/datasets/piimb/pii-masking-benchmark",
      "split_uses": [
        {
          "config": "sentences",
          "split": "test",
          "allowed_use": "heldout_validation",
          "split_purpose": "validation",
          "adapter_family": "privacy",
          "notes": "Use for PII recall, redaction routing, false positives, and safe allow rate."
        },
        {
          "config": "full_text",
          "split": "test",
          "allowed_use": "external_reporting",
          "split_purpose": "public_claim",
          "adapter_family": "privacy",
          "notes": "Use only for externally reported privacy-control claims; do not tune on this config/split."
        }
      ]
    },
    {
      "dataset_name": "ai4privacy/pii-masking-openpii-1m",
      "license": "other; dataset card describes CC-BY-4.0",
      "task_type": "multilingual_privacy_pii_detection",
      "adapter_families": [
        "privacy",
        "security",
        "support"
      ],
      "source_url": "https://huggingface.co/datasets/ai4privacy/pii-masking-openpii-1m",
      "split_uses": [
        {
          "config": "default",
          "split": "train",
          "allowed_use": "calibration",
          "split_purpose": "tuning",
          "adapter_family": "privacy",
          "notes": "Use for multilingual PII detector calibration and entity taxonomy expansion only."
        },
        {
          "config": "default",
          "split": "validation",
          "allowed_use": "heldout_validation",
          "split_purpose": "validation",
          "adapter_family": "privacy",
          "notes": "Use for held-out multilingual privacy validation after calibration."
        }
      ]
    },
    {
      "dataset_name": "nvidia/Nemotron-PII",
      "license": "cc-by-4.0",
      "task_type": "pii_phi_detection",
      "adapter_families": [
        "privacy",
        "medical",
        "finance",
        "legal"
      ],
      "source_url": "https://huggingface.co/datasets/nvidia/Nemotron-PII",
      "split_uses": [
        {
          "config": "default",
          "split": "train",
          "allowed_use": "calibration",
          "split_purpose": "tuning",
          "adapter_family": "privacy",
          "notes": "Use for domain/entity coverage expansion, especially PII/PHI-like text."
        },
        {
          "config": "default",
          "split": "test",
          "allowed_use": "heldout_validation",
          "split_purpose": "validation",
          "adapter_family": "privacy",
          "notes": "Use for privacy and regulated-domain held-out checks."
        }
      ]
    },
    {
      "dataset_name": "NovachronoAI/RAG-Grounded-QA-188k",
      "license": "cc-by-sa-4.0",
      "task_type": "grounded_qa_unanswerable_detection",
