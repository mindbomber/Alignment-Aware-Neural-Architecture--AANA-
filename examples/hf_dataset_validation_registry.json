        "research_grounding",
        "support",
        "education",
        "legal",
        "pharma"
      ],
      "source_url": "https://huggingface.co/datasets/NovachronoAI/RAG-Grounded-QA-188k",
      "split_uses": [
        {
          "config": "20k_subset",
          "split": "train",
          "allowed_use": "calibration",
          "split_purpose": "tuning",
          "adapter_family": "research_grounding",
          "notes": "Use for groundedness thresholds, unanswerable routing, and citation sufficiency calibration."
        },
        {
          "config": "20k_subset",
          "split": "test",
          "allowed_use": "heldout_validation",
          "split_purpose": "validation",
          "adapter_family": "research_grounding",
          "notes": "Use for held-out grounded QA validation."
        },
        {
          "config": "full",
          "split": "test",
          "allowed_use": "external_reporting",
          "split_purpose": "public_claim",
          "adapter_family": "research_grounding",
