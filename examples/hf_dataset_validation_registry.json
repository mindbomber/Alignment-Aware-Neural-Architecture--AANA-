      "task_type": "hallucination_detection",
      "adapter_families": [
        "research_grounding",
        "support",
        "medical",
        "legal"
      ],
      "source_url": "https://huggingface.co/datasets/PatronusAI/HaluBench",
      "split_uses": [
        {
          "config": "default",
          "split": "test",
          "allowed_use": "heldout_validation",
          "split_purpose": "validation",
          "adapter_family": "research_grounding",
          "notes": "Use for unsupported-claim recall and over-refusal measurement; license restricts commercial use."
        }
      ]
    },
    {
