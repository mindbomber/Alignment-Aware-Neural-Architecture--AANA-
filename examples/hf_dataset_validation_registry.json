      ],
      "source_url": "https://huggingface.co/datasets/NousResearch/hermes-function-calling-v1",
      "split_uses": [
        {
          "config": "func-calling-singleturn",
          "split": "train",
          "allowed_use": "calibration",
          "split_purpose": "tuning",
          "adapter_family": "agent_tool_gate",
          "notes": "Use for tool-call schema and argument-shape calibration only."
        },
        {
          "config": "func-calling",
          "split": "train",
          "allowed_use": "heldout_validation",
          "split_purpose": "validation",
          "adapter_family": "agent_tool_gate",
          "notes": "Use a disjoint config for validation if single-turn was used for calibration."
        }
      ]
    }
  ]
}
