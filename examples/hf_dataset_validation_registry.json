    },
    {
      "dataset_name": "lihaonan0716/mcphunt-agent-traces",
      "license": "cc-by-4.0",
      "task_type": "mcp_agent_safety_traces",
      "adapter_families": [
        "agent_tool_gate",
        "security",
        "privacy",
        "mcp"
      ],
      "source_url": "https://huggingface.co/datasets/lihaonan0716/mcphunt-agent-traces",
      "split_uses": [
        {
