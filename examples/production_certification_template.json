{
  "production_certification_version": "0.1",
  "policy_name": "AANA Production Certification Standard",
  "owner": "AANA Maintainers",
  "shadow_mode": {
    "minimum_duration_days": 14,
    "minimum_records": 100,
    "required_adapter_ids": []
  },
  "metrics": {
    "required": [
      "adapter_error_count",
      "aix_decision_count",
      "aix_hard_blocker_count",
      "aix_score_average",
      "false_accept_rate",
      "false_block_rate",
      "gate_decision_count",
      "human_review_turnaround_time",
      "latency",
      "over_refusal_rate",
      "recommended_action_count",
      "shadow_records_total",
      "shadow_would_action_count",
      "violation_code_count"
    ],
    "minimum_aix_score_average": 0.85,
    "minimum_aix_score_min": 0.5,
    "maximum_aix_hard_blockers": 0,
    "allowed_aix_decisions": ["accept", "revise"]
  },
  "human_review": {
    "required_for": [
      "high-impact decisions",
      "low-confidence verifier results",
      "irreversible external actions"
    ],
    "required_routes": [
      "AANA Local Human Review Queue",
      "AANA Local Incident Log"
    ]
  },
  "connector_evidence": {
    "required_connectors": [
      "crm_support",
      "email_send",
      "calendar",
      "iam",
      "ci",
      "deployment",
      "billing",
      "data_export",
      "workspace_files"
    ],
    "auth_boundary_required": true,
    "freshness_slo_required": true,
    "redaction_required": true,
    "failure_modes_required": true
  },
  "audit_retention": {
    "minimum_days": 365,
    "immutable_required": true,
    "redaction_required": true,
    "access_review_cadence": "quarterly"
  },
  "approvals": {
    "domain_owner_signoff": true,
    "security_signoff": true,
    "governance_signoff": true
  }
}
