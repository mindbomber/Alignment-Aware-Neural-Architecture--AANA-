{
  "review_version": "0.1",
  "review_id": "aana-support-security-privacy-review-2026-05",
  "title": "AANA Support Security and Privacy Review",
  "scope": {
    "product_boundary": "AANA runtime guardrail layer for support workflows.",
    "adapters": [
      "support_reply",
      "crm_support_reply",
      "email_send_guardrail",
      "ticket_update_checker",
      "invoice_billing_reply"
    ],
    "public_surfaces": [
      "workflow_contract",
      "agent_event",
      "http_bridge",
      "python_sdk",
      "cli"
    ],
    "out_of_scope": [
      "Production TLS termination",
      "Customer identity provider enforcement",
      "Immutable external audit storage",
      "Live CRM/order/email connector authorization",
      "Domain-owner production approval"
    ]
  },
  "deployment_position": {
    "repo_local_status": "demo-ready/pilot-ready/production-candidate",
    "production_status": "not production-certified by local tests alone",
    "production_blockers": [
      "live evidence connector permission review",
      "domain owner signoff",
      "audit retention policy approval",
      "observability approval",
      "human review staffing and SLA",
      "security review approval",
      "deployment manifest approval",
      "incident response plan approval",
      "measured pilot results",
      "rate limit and abuse plan approved by deployment owner"
    ]
  },
  "support_data_flow": [
    {
      "step": "agent_candidate",
      "data": "Raw support prompt, candidate reply/action, adapter id, allowed actions.",
      "threats": [
        "raw prompt or candidate leaking to logs",
        "candidate contains private payment data or internal CRM note"
      ],
      "mitigations": [
        "metadata-only audit records",
        "support verifier blocks private data and internal CRM leakage",
        "HTTP bridge structured errors avoid raw exception payload text"
      ]
    },
    {
      "step": "evidence_retrieval",
      "data": "CRM, order, policy, ticket, email recipient, attachment metadata, and billing evidence.",
      "threats": [
        "over-broad connector permissions",
        "stale evidence",
        "unredacted evidence passed to audit"
      ],
      "mitigations": [
        "evidence source IDs and fingerprints are audited instead of raw evidence",
        "evidence registry declares connector boundaries",
        "production requires external connector manifests and owner approval"
      ]
    },
    {
      "step": "runtime_gate",
      "data": "Verifier report, violations, AIx, correction route, safe output.",
      "threats": [
        "unsafe accept",
        "wrong correction route",
        "raw safe response stored in audit"
      ],
      "mitigations": [
        "common verifier report shape",
        "route maps for extracted verifier families",
        "audit-safe summaries omit raw output text"
      ]
    },
    {
      "step": "bridge_and_audit",
      "data": "HTTP request metadata, decision metadata, audit JSONL.",
      "threats": [
        "token leakage",
        "request flood",
        "audit record stores customer data"
      ],
      "mitigations": [
        "Authorization and X-AANA-Token support",
        "redacted bridge logs and config route",
        "body limits, read timeout, and optional per-client rate limit",
        "audit validation and redaction tests"
      ]
    }
  ],
  "bridge_auth_review": {
    "status": "repo_local_reviewed",
    "post_auth_required": true,
    "accepted_headers": [
      "Authorization: Bearer <token>",
      "X-AANA-Token: <token>"
    ],
    "token_sources": [
      "env",
      "file"
    ],
    "token_rotation_path": "auth token file is reread per request when --auth-token-file is used",
    "raw_token_logged": false,
    "structured_unauthorized_error": true,
    "evidence": [
      "eval_pipeline/agent_server.py:_authorized",
      "eval_pipeline/agent_server.py:_resolved_auth_token",
      "eval_pipeline/agent_server.py:_redact_log_text"
